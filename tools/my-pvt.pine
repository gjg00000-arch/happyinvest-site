//@version=5
// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © 사용자 정의 — MY Price Volume Trend · 웹훅 알림
// 차트 알림: "alert() 함수 호출" + Webhook URL. 메시지는 {{message}} 권장.
indicator(
     title                = "MY_Price Volume Trend",
     shorttitle           = "MY_PVT",
     format               = format.inherit,
     precision            = 4,
     overlay              = false,
     explicit_plot_zorder = true,
     max_bars_back        = 5000,
     max_lines_count      = 500,
     max_labels_count     = 500
     )

webhookUrl = input.string(
     "https://magicindicatorglobal.com/YOUR_WEBHOOK_PATH",
     "Webhook URL (알림 설정에 동일하게 입력)",
     group = "웹훅",
     tooltip = "Pine은 HTTP 불가. 차트 → 알림 → Webhook에 이 URL을 입력."
     )

signal = input.int(10, "signal", minval = 1, group = "계산")
maKind = input.string("지수", "이평종류", options = ["지수", "단순", "가중"], group = "계산")
period = input.int(10, "H/L 기간", minval = 1, group = "계산")
showH = input.bool(false, "H 표시", group = "표시")
showL = input.bool(false, "L 표시", group = "표시")

sendOnStart = true
alsoEveryClose = false
evtName = "my_pvt_online"

chg = (bar_index > 0 and not na(close[1]) and close[1] != 0) ? (close - close[1]) / close[1] * nz(volume, 0) : 0.0
pvt = ta.cum(chg)

emaPVT = ta.ema(pvt, signal)
smaPVT = ta.sma(pvt, signal)
wmaPVT = ta.wma(pvt, signal)
pvtMa = maKind == "지수" ? emaPVT : maKind == "단순" ? smaPVT : wmaPVT

H = ta.highest(pvt, period)
L = ta.lowest(pvt, period)
DC = pvt < pvtMa ? pvtMa - (pvtMa - pvt) : pvtMa

fillTransp = 75
pPVT = plot(pvt, title = "PVT", color = color.fuchsia, linewidth = 2)
pSig = plot(pvtMa, title = "Pvt이평", color = color.yellow, linewidth = 2)
plot(showH ? H : na, title = "H", color = color.blue, linewidth = 1)
plot(DC, title = "DC", color = color.blue, linewidth = 1)
plot(showL ? L : na, title = "L", color = color.silver, linewidth = 1)
fill(pPVT, pSig, color = pvt > pvtMa ? color.new(color.fuchsia, fillTransp) : color.new(color.yellow, fillTransp))

jsonEsc(string s) =>
    str.replace_all(str.replace_all(s, "\\", "\\\\"), "\"", "\\\"")

closeNumJson() =>
    na(close) ? "null" : str.tostring(close, format.mintick)

indNumJson(float v) =>
    na(v) ? "null" : str.tostring(v, "#.########")

tfStr = timeframe.period

varip bool _startSent = false

string jStart =
     "{\"event\":\"" + evtName +
     "\",\"kind\":\"indicator_start\",\"indicator\":\"MY_PVT\",\"ticker\":\"" +
     jsonEsc(syminfo.ticker) + "\",\"exchange\":\"" + jsonEsc(syminfo.prefix) + "\"}"

string jBar =
     "{\"event\":\"my_pvt_bar\",\"kind\":\"bar_close\",\"indicator\":\"MY_PVT\",\"ticker\":\"" +
     jsonEsc(syminfo.ticker) + "\",\"exchange\":\"" + jsonEsc(syminfo.prefix) + "\",\"tf\":\"" +
     jsonEsc(tfStr) + "\",\"signal\":" + str.tostring(signal) + ",\"maKind\":\"" + jsonEsc(maKind) +
     "\",\"periodHL\":" + str.tostring(period) + ",\"close\":" + closeNumJson() +
     ",\"pvt\":" + indNumJson(pvt) + ",\"pvtMa\":" + indNumJson(pvtMa) + ",\"dc\":" + indNumJson(DC) +
     ",\"h\":" + indNumJson(H) + ",\"l\":" + indNumJson(L) +
     ",\"bar_time\":" + str.tostring(time) + "}"

if sendOnStart and barstate.isconfirmed and barstate.isrealtime and not _startSent
    alert(jStart, alert.freq_once_per_bar_close)
    _startSent := true

if alsoEveryClose and barstate.isconfirmed
    alert(jBar, alert.freq_once_per_bar_close)
