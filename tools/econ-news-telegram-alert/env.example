# Finnhub: https://finnhub.io/register (무료 API 키)
FINNHUB_API_KEY=

# Telegram Bot: @BotFather 에서 봇 생성 후 토큰
TELEGRAM_BOT_TOKEN=
# 채팅 ID (본인·그룹). @userinfobot 등으로 확인
TELEGRAM_CHAT_ID=

# 발표 몇 분 전 알림 (기본 30)
ALERT_MINUTES_BEFORE=30

# 몇 초마다 캘린더 재조회 (기본 120)
POLL_INTERVAL_SEC=120

# 고임팩트만: high | high,medium
IMPACT_LEVELS=high

# 국가 코드 쉼표 구분 (미국 중심, 필요 시 EU 등 추가)
EVENT_COUNTRIES=US

# API가 날짜+시각만 주고 타임존이 불명확할 때 붙이는 기준 (미국 지표는 America/New_York 가 맞는 경우가 많음)
SOURCE_TIMEZONE=UTC

# 메시지에 표시할 현지 시간 (투자자 기준)
DISPLAY_TIMEZONE=America/New_York

# 1=전송 없이 로그만
DRY_RUN=0

# (선택) 웹훅/Cron이 subprocess로 1회만 돌릴 때: python run.py --once
# Docker·Nginx·운영 절차: 저장소 server/economic-cron/DEPLOY.md
